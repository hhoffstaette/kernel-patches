Change minimum per-inode writeback size to 64 MB, see
https://lore.kernel.org/all/20251017034611.651385-1-hch@lst.de/
for motivation. The "reduced fairness" between inodes is overrated,
since writeback is asynchronous; in exchange this massively increases
throughput for large files esp. on rotational devices.

--- a/include/linux/writeback.h
+++ b/include/linux/writeback.h
@@ -371,8 +371,8 @@ void sb_mark_inode_writeback(struct inod
 void sb_clear_inode_writeback(struct inode *inode);
 
 /*
- * 4MB minimal write chunk size
+ * 64MB minimal write chunk size
  */
-#define MIN_WRITEBACK_PAGES	(4096UL >> (PAGE_SHIFT - 10))
+#define MIN_WRITEBACK_PAGES	(65536UL >> (PAGE_SHIFT - 10))
 
 #endif		/* WRITEBACK_H */
